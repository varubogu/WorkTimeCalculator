{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/schemas/wtc-work-entries.schema.json",
  "title": "Work Time Calculator Work Entries",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "entries"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "schema": {
      "const": "wtc-work-entries/v1"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "start", "end", "breakMin", "vacation"],
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "start": {
            "type": "string",
            "pattern": "^(\\d{1,2}:\\d{2})?$"
          },
          "end": {
            "type": "string",
            "pattern": "^(\\d{1,2}:\\d{2})?$"
          },
          "breakMin": {
            "type": "number",
            "minimum": 0
          },
          "vacation": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
